{
  "name": "@edgecms/runtime",
  "version": "0.0.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --sourcemap",
    "test": "vitest run && vitest run --config vitest.workers.config.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@edgecms/adapter-d1": "workspace:*",
    "@edgecms/config": "workspace:*",
    "@edgecms/core": "workspace:*",
    "@edgecms/storage-r2": "workspace:*",
    "hono": "^4.12.31",
    "zod": "^4.4.3",
    "@edgecms/adapter-postgres": "workspace:*",
    "@edgecms/adapter-mysql": "workspace:*",
    "graphql": "^16.9.0"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "0.12.0",
    "@cloudflare/workers-types": "^4.20260702.1",
    "tsup": "^8.4.0",
    "vitest": "^3.1.0"
  }
}
