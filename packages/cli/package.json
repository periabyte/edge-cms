{
  "name": "@edgecms/cli",
  "version": "0.0.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./bin": {
      "import": "./dist/bin.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/bin.ts --format esm --dts --sourcemap",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@clack/prompts": "^0.9.0",
    "@edgecms/adapter-d1": "workspace:*",
    "@edgecms/admin": "workspace:*",
    "@edgecms/config": "workspace:*",
    "@edgecms/core": "workspace:*",
    "@edgecms/runtime": "workspace:*",
    "commander": "^13.1.0",
    "esbuild": "^0.24.0",
    "wrangler": "^4.112.0",
    "@edgecms/adapter-relational": "workspace:*",
    "@edgecms/adapter-postgres": "workspace:*",
    "@edgecms/adapter-mysql": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsup": "^8.4.0",
    "vitest": "^3.1.0"
  },
  "bin": {
    "kalayaan": "./dist/bin.js"
  }
}
