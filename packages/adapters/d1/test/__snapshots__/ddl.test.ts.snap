// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`emitDDL golden output > initial migration for the blog schema 1`] = `
"CREATE TABLE "authors" (
  "id" TEXT PRIMARY KEY,
  "avatar_id" TEXT REFERENCES "media"("id") ON DELETE SET NULL,
  "name" TEXT,
  "created_at" INTEGER NOT NULL,
  "updated_at" INTEGER NOT NULL,
  "published_at" INTEGER
);
CREATE INDEX "idx_authors_avatar" ON "authors" ("avatar_id");
CREATE TABLE "posts" (
  "id" TEXT PRIMARY KEY,
  "entity_id" TEXT NOT NULL,
  "locale" TEXT NOT NULL DEFAULT 'en',
  "author_id" TEXT REFERENCES "authors"("id") ON DELETE RESTRICT,
  "body" TEXT,
  "cover_id" TEXT REFERENCES "media"("id") ON DELETE SET NULL,
  "slug" TEXT,
  "status" TEXT DEFAULT 'draft' CHECK ("status" IN ('draft', 'published')),
  "title" TEXT NOT NULL,
  "created_at" INTEGER NOT NULL,
  "updated_at" INTEGER NOT NULL,
  "published_at" INTEGER
);
CREATE TABLE "posts_tags" (
  "owner_id" TEXT NOT NULL REFERENCES "posts"("id") ON DELETE CASCADE,
  "ref_id" TEXT NOT NULL REFERENCES "tags"("id") ON DELETE CASCADE,
  "sort" INTEGER NOT NULL DEFAULT 0,
  PRIMARY KEY ("owner_id", "ref_id")
);
CREATE UNIQUE INDEX "ux_posts_entity_locale" ON "posts" ("entity_id", "locale");
CREATE INDEX "idx_posts_author" ON "posts" ("author_id");
CREATE INDEX "idx_posts_cover" ON "posts" ("cover_id");
CREATE UNIQUE INDEX "ux_posts_slug" ON "posts" ("slug", "locale");
CREATE TABLE "tags" (
  "id" TEXT PRIMARY KEY,
  "name" TEXT NOT NULL,
  "created_at" INTEGER NOT NULL,
  "updated_at" INTEGER NOT NULL,
  "published_at" INTEGER
);
CREATE UNIQUE INDEX "ux_tags_name" ON "tags" ("name");"
`;
