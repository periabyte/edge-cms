---
interface Props {
  active?: "home" | "about";
}
const { active } = Astro.props;
---

<header class="ec-header">
  <div class="ec-wrap ec-header-inner">
    <a href="/" class="ec-logo">
      <img src="/assets/logo.svg" alt="" width="27" height="27" />
      <span>kalayaan</span>
    </a>
    <nav class="ec-nav-links">
      <a class="ec-link" href="/#how">How it works</a>
      <a class="ec-link" href="/#features">Features</a>
      <a class="ec-link" href="/#cost">Cost</a>
      <a class="ec-link" href="/guides/quickstart/">Docs</a>
      <a class="ec-link" href="/about" aria-current={active === "about" ? "page" : undefined}>About</a>
    </nav>
    <div style="margin-left:auto;display:flex;align-items:center;gap:12px">
      <button type="button" class="ec-theme-toggle" id="ec-theme-toggle" aria-label="Toggle theme">
        <svg id="ec-theme-icon-dark" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"></circle><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"></path></svg>
        <svg id="ec-theme-icon-light" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" style="display:none"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path></svg>
      </button>
      <a class="ec-gh-link" href="https://github.com/periabyte/kalayaan-cms" target="_blank" rel="noopener">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor"><path d="M12 .5C5.73.5.5 5.73.5 12c0 5.08 3.29 9.39 7.86 10.91.57.1.78-.25.78-.55v-2.15c-3.2.7-3.87-1.36-3.87-1.36-.53-1.33-1.29-1.69-1.29-1.69-1.05-.72.08-.7.08-.7 1.17.08 1.78 1.2 1.78 1.2 1.03 1.77 2.71 1.26 3.37.96.1-.75.4-1.26.73-1.55-2.55-.29-5.24-1.28-5.24-5.68 0-1.26.45-2.28 1.19-3.09-.12-.29-.52-1.46.11-3.05 0 0 .97-.31 3.18 1.18a11 11 0 0 1 5.79 0c2.21-1.49 3.18-1.18 3.18-1.18.63 1.59.23 2.76.11 3.05.74.81 1.19 1.83 1.19 3.09 0 4.41-2.69 5.39-5.25 5.67.41.36.78 1.08.78 2.18v3.23c0 .3.21.66.79.55A10.51 10.51 0 0 0 23.5 12c0-6.27-5.23-11.5-11.5-11.5z"></path></svg>
        github
      </a>
    </div>
  </div>
</header>

<script>
  const STORAGE_KEY = "kalayaan-landing-theme";
  function apply(theme: string) {
    document.documentElement.setAttribute("data-theme", theme);
    const dark = document.getElementById("ec-theme-icon-dark");
    const light = document.getElementById("ec-theme-icon-light");
    if (dark && light) {
      dark.style.display = theme === "dark" ? "block" : "none";
      light.style.display = theme === "dark" ? "none" : "block";
    }
  }
  const stored = localStorage.getItem(STORAGE_KEY);
  const initial = stored || (window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light");
  apply(initial);
  document.getElementById("ec-theme-toggle")?.addEventListener("click", () => {
    const current = document.documentElement.getAttribute("data-theme") === "dark" ? "dark" : "light";
    const next = current === "dark" ? "light" : "dark";
    localStorage.setItem(STORAGE_KEY, next);
    apply(next);
  });
</script>
